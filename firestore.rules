rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // ⚠️ CHANGE THIS to your own email — only this account can set
    // gameweeks/deadlines and enter match results.
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "sam.vinall@hotmail.co.uk";
    }

    // The guest list. config/allowlist holds { emails: [ "a@x.com", ... ] }
    // (lower-cased). Only allow-listed accounts (plus the admin) can read or
    // write any game data -- this is the real gate, not just the UI. The
    // client also checks this list on sign-in and signs out anyone missing,
    // but even if that were bypassed the rules below still refuse them.
    function isAllowed() {
      return isAdmin() || (
        isSignedIn()
        && exists(/databases/$(database)/documents/config/allowlist)
        && request.auth.token.email in get(/databases/$(database)/documents/config/allowlist).data.emails
      );
    }

    // The season-predictions lock (transfer-window close), stored on
    // config/season. Null if not set yet (predictions open until then).
    function seasonDeadline() {
      return exists(/databases/$(database)/documents/config/season)
        ? get(/databases/$(database)/documents/config/season).data.predictionsDeadline
        : null;
    }

    // config holds current gameweek, the guest list, mirrored fixtures /
    // players / standings, and the season-prediction deadline + results. Any
    // signed-in account may read config so the sign-in gate can look itself up
    // in the allowlist before it's been admitted; only the admin can write it
    // (the sync writes players/standings/fixtures via the Admin SDK, which
    // bypasses rules).
    match /config/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // season_picks/{uid} holds one player's GW0 predictions
    // { uid, name, email, goldenBootId, goldenBootName, champion }. Like weekly
    // picks, your own is always readable but others' stay hidden until the
    // predictions deadline passes, and you can only write your own, before the
    // deadline.
    match /season_picks/{uid} {
      allow read: if isAllowed() && (
        request.auth.uid == uid
        || (seasonDeadline() != null && request.time >= seasonDeadline())
      );
      allow create, update: if isAllowed()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && (seasonDeadline() == null || request.time < seasonDeadline());
      allow delete: if false;
    }

    // results/{gw_team} holds { gameweek, team, result: "win"|"draw"|"loss" }
    // Only you can enter these, and only from the real match outcome.
    match /results/{doc} {
      allow read: if isAllowed();
      allow write: if isAdmin();
    }

    // picks/{uid_gwN} holds { uid, name, email, team, gameweek }
    match /picks/{pickId} {
      // A pick is only readable if it's your own, if it belongs to a
      // gameweek earlier than the one currently open (already played), or
      // if it's the current gameweek and that gameweek's deadline has
      // passed. Future weeks' picks (players can now pre-pick ahead) stay
      // hidden until that week actually becomes current-and-locked. This
      // stops anyone reading rivals' unplayed picks straight out of the
      // network tab before kickoff -- they're genuinely hidden, not just
      // hidden in the UI. NB: the client must query picks in a way that
      // only matches readable docs (see loadEverything in app.js), because
      // Firestore rejects a query that could return a doc the rule forbids
      // -- rules filter nothing on their own.
      allow read: if isAllowed() && (
        resource.data.uid == request.auth.uid
        || resource.data.gameweek < get(/databases/$(database)/documents/config/current).data.gameweek
        || (resource.data.gameweek == get(/databases/$(database)/documents/config/current).data.gameweek
            && request.time >= get(/databases/$(database)/documents/config/current).data.deadline)
      );

      // A pick can be created OR changed, only by the account it belongs
      // to, only before that gameweek's own deadline. Players may pre-pick
      // any future gameweek; each pick locks at its week's real kickoff,
      // read from the per-gameweek deadline map in config/schedule (keyed
      // by gameweek string). Past weeks' deadlines have passed so they're
      // refused; an unknown gameweek is refused by the `in` guard.
      // `resource` is null on create and the existing doc on update, so the
      // ownership check covers both cases -- nobody can overwrite someone
      // else's pick.
      allow create, update: if isAllowed()
        && request.resource.data.uid == request.auth.uid
        && (resource == null || resource.data.uid == request.auth.uid)
        && string(request.resource.data.gameweek) in get(/databases/$(database)/documents/config/schedule).data.deadlines
        && request.time < get(/databases/$(database)/documents/config/schedule).data.deadlines[string(request.resource.data.gameweek)];

      // You can remove ("unselect") your own pick, but only before that
      // gameweek's deadline -- once a week locks, picks are final.
      allow delete: if isAllowed()
        && resource.data.uid == request.auth.uid
        && string(resource.data.gameweek) in get(/databases/$(database)/documents/config/schedule).data.deadlines
        && request.time < get(/databases/$(database)/documents/config/schedule).data.deadlines[string(resource.data.gameweek)];
    }

    // profiles/{uid} holds { uid, email, name } -- a player's chosen display
    // name. Anyone allow-listed can read them (names show on the sheet/table);
    // you can only write your own, except the admin who can override any.
    match /profiles/{uid} {
      allow read: if isAllowed();
      allow write: if (isAllowed() && request.auth.uid == uid) || isAdmin();
    }
  }
}
